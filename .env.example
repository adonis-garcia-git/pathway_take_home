# ── Convex ──────────────────────────────────────────────────────────
# Written automatically by `npx convex dev`. Do not hand-edit.
# Get them via: pnpm dlx convex dev --once --configure new
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=

# ── Anthropic (Claude) ──────────────────────────────────────────────
# Used inside Convex actions for menu parsing and quote parsing.
# Get one at: https://console.anthropic.com/settings/keys
# Must also be set in Convex env: `npx convex env set ANTHROPIC_API_KEY <key>`
ANTHROPIC_API_KEY=

# ── USDA Market News MARS API ───────────────────────────────────────
# Free tier. Register: https://marsapi.ams.usda.gov/
# Must also be set in Convex env: `npx convex env set USDA_MARS_API_KEY <key>`
USDA_MARS_API_KEY=

# ── Maileroo (outbound email + inbound webhooks) ────────────────────
# Free tier. Dashboard: https://app.maileroo.com
# 1. Create a Sending Key (Sending → API Keys). That's MAILEROO_SENDING_KEY.
# 2. Verify a domain (Domains → Add). That's MAIL_DOMAIN (e.g. mail.yourdomain.com).
# 3. Configure Inbound Routing to POST to your Convex httpAction URL
#    (printed by `npx convex dev` — e.g. https://<dep>.convex.site/maileroo/inbound).
# Note: inbound has NO signing secret. We authenticate by calling the
# payload's `validation_url` once per message.
# Both must also be set in Convex env: `npx convex env set <KEY> <value>`
MAILEROO_SENDING_KEY=
MAIL_DOMAIN=

# ── Google Places API (New) ─────────────────────────────────────────
# Get one: https://console.cloud.google.com/apis/credentials
# Enable: "Places API (New)" in the same project.
# Restrict the key to Places API + your domain/IPs in production.
# Must also be set in Convex env: `npx convex env set GOOGLE_PLACES_API_KEY <key>`
GOOGLE_PLACES_API_KEY=
